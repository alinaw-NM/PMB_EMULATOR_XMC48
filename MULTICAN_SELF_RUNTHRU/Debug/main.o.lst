 1455              	.LFB258:
 189:../main.c     **** 
 190:../main.c     **** /* ============================================================
 191:../main.c     ****  * Table-driven full loopback test suite
 192:../main.c     ****  * ============================================================
 193:../main.c     ****  *
 194:../main.c     ****  * Each entry maps a data_id to the byte range in PMB_Registers_t that
 195:../main.c     ****  * the emulator reads when building the response.  The runner writes a fixed
 196:../main.c     ****  * seed pattern to those raw struct bytes, then issues a CAN read request and
 197:../main.c     ****  * verifies that exactly those bytes come back in the response payload.
 198:../main.c     ****  *
 199:../main.c     ****  * Seed odd bytes (hi of each uint16_t pair) are 0x01/0x04/0x07 — all ≤ 0x0F
 200:../main.c     ****  * — so pack12's upper-nibble mask leaves them unchanged and expected == seed
 201:../main.c     ****  * for every register type without any special casing.
 202:../main.c     ****  *
 203:../main.c     ****  * Special case 0xCC (REG_NEG_LIM_GRP2): the emulator packs its two fields at
 204:../main.c     ****  * payload bytes [2..5] instead of [0..3].  payload_off captures this offset.
 205:../main.c     ****  * ============================================================ */
 206:../main.c     **** 
 207:../main.c     **** typedef struct {
 208:../main.c     ****     uint16_t data_id;
 209:../main.c     ****     uint16_t reg_offset;   /* offsetof(PMB_Registers_t, field) */
 210:../main.c     ****     uint8_t  n_active;     /* bytes written to the struct / verified in response */
 211:../main.c     ****     uint8_t  payload_off;  /* byte index in data[0..5] where the fields begin    */
 212:../main.c     **** } PMBTestVec_t;
 213:../main.c     **** 
 214:../main.c     **** static const uint8_t s_seed6[6] = {0x23U, 0x01U, 0x56U, 0x04U, 0x89U, 0x07U};
 215:../main.c     **** 
 216:../main.c     **** #define OFS(f) ((uint16_t)offsetof(PMB_Registers_t, f))
 217:../main.c     **** 
 218:../main.c     **** static const PMBTestVec_t s_test_table[] = {
 219:../main.c     **** 
