   1:../scud_bms.c **** /*
   2:../scud_bms.c ****  * SCUD BMS RS485 driver for XMC4800.
   3:../scud_bms.c ****  *
   4:../scud_bms.c ****  * Implements the YDT 1363.3-style ASCII-hex frame protocol used by SCUD BMS
   5:../scud_bms.c ****  * modules (ref: "SCUD BMS485 协议 A2 修订版 20251015.pdf").
   6:../scud_bms.c ****  *
   7:../scud_bms.c ****  * Wire format (all chars between SOI and EOI are uppercase ASCII hex):
   8:../scud_bms.c ****  *   ~ VER(2) ADR(2) CID1(2) CID2(2) LENGTH(4) INFO(LENID) CHKSUM(4) \r
   9:../scud_bms.c ****  *
  10:../scud_bms.c ****  * Requires two DAVE APPs in the project:
  11:../scud_bms.c ****  *   UART_0           — 115200 8N1, TX=P2.14, RX=P2.15 (USIC1_CH0)
  12:../scud_bms.c ****  *   RS485_DE         — output, P5.8, initial LOW (RX mode)
  13:../scud_bms.c ****  */
  14:../scud_bms.c **** 
  15:../scud_bms.c **** #include "scud_bms.h"
  16:../scud_bms.c **** #include "DAVE.h"
  17:../scud_bms.c **** 
  18:../scud_bms.c **** /* Access the underlying USIC channel from the DAVE UART APP handle. */
  19:../scud_bms.c **** #define BMS_CH  (UART_0.channel)
  20:../scud_bms.c **** 
  21:../scud_bms.c **** /* -------------------------------------------------------------------------
  22:../scud_bms.c ****  * Protocol constants
  23:../scud_bms.c ****  * ---------------------------------------------------------------------- */
  24:../scud_bms.c **** #define SCUD_VER          0x22U   /* protocol version 2.2 */
  25:../scud_bms.c **** #define SCUD_ADR          0x00U   /* pack address */
  26:../scud_bms.c **** #define SCUD_CID1         0x4AU   /* BMS device type */
  27:../scud_bms.c **** #define SCUD_CID2_ANALOG  0x42U
  28:../scud_bms.c **** #define SCUD_CID2_ALARM   0x44U
  29:../scud_bms.c **** #define SCUD_CMD_GROUP    0x01U   /* pack 1 */
  30:../scud_bms.c **** 
  31:../scud_bms.c **** /*
  32:../scud_bms.c ****  * Timeout expressed as a tight-loop iteration count.
  33:../scud_bms.c ****  * At 144 MHz with ~4 cycles/iteration this is roughly 1 second,
  34:../scud_bms.c ****  * conservative enough to cover the BMS response time.
  35:../scud_bms.c ****  */
  36:../scud_bms.c **** #define SCUD_TIMEOUT_TICKS   36000000U
  37:../scud_bms.c **** 
  38:../scud_bms.c **** 
